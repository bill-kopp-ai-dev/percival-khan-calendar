# Percival Khan Calendar — Environment Variables
# Copy to .env and edit for local development.
#
# All variables below are optional. Defaults are applied by
# `percival_khan_calendar.constants` at import time.

# Workspace directory. Defaults to ~/.nanobot/workspace/khalCalendar
# KHAN_WORKSPACE_DIR=/home/your-user/.nanobot/workspace/khalCalendar

# Default calendar name. Defaults to "nanobot".
# KHAN_DEFAULT_CALENDAR=nanobot

# Locale settings (passed to khal.conf). Defaults shown.
# KHAN_TIMEFORMAT=%H:%M
# KHAN_DATEFORMAT=%d/%m/%Y

# Timeout (seconds) for khal subprocess calls. Defaults to 15.
# KHAN_SUBPROCESS_TIMEOUT=15

# Enable lock file on writes (Phase 6). Defaults to true.
# KHAN_ENABLE_LOCK=true

# Log level. Defaults to INFO.
# KHAN_LOG_LEVEL=INFO
